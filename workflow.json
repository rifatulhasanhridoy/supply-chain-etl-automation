    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO fact_order_line (\n    order_id, \n    order_placement_date, \n    customer_id, \n    product_id, \n    order_qty, \n    agreed_delivery_date, \n    actual_delivery_date, \n    delivery_qty, \n    in_full, \n    on_time, \n    on_time_in_full\n) \nVALUES (\n    '{{ $json.order_id }}', \n    '{{ $json.order_placement_date.split(\"-\").reverse().join(\"-\") }}', \n    '{{ $json.customer_id }}', \n    '{{ $json.product_id }}', \n    {{ parseInt($json.order_qty) }}, \n    '{{ $json.agreed_delivery_date.split(\"-\").reverse().join(\"-\") }}', \n    '{{ $json.actual_delivery_date.split(\"-\").reverse().join(\"-\") }}', \n    {{ parseInt($json.delivery_qty) }}, \n    {{ parseInt($json['In Full']) }}, \n    {{ parseInt($json['On Time']) }}, \n    {{ parseInt($json['On Time In Full']) }}\n);",
        "options": {}
      },
      "type": "n8n-nodes-base.microsoftSql",
      "typeVersion": 1.1,
