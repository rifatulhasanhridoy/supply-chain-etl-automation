    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    COUNT(*) as total_orders,\n    SUM(order_qty) as total_units_ordered,\n    SUM(delivery_qty) as total_units_delivered,\n    SUM(order_qty - delivery_qty) as total_shorted_units,\n    AVG(CAST(on_time as FLOAT)) * 100 as on_time_rate,\n    AVG(CAST(in_full as FLOAT)) * 100 as in_full_rate,\n    AVG(CAST(on_time_in_full as FLOAT)) * 100 as otif_rate,\n    AVG(CAST(DATEDIFF(day, agreed_delivery_date, actual_delivery_date) as FLOAT)) as avg_days_delayed\nFROM fact_order_line",
        "options": {}
      },
